# OpenAI (値は vocab-trainer/.env からコピー; OPENAI_MODEL には OPENAI_MODEL_MINI の値)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5-mini

# アップロード先の vocab-trainer backend
# ローカルテスト時: http://localhost:3000 / 本番: Cloud Run の backend URL
CLOUD_API_BASE_URL=http://localhost:3000
# 成功後リンク用のフロントエンドURL (ローカル: http://localhost:5173)
CLOUD_UI_URL=http://localhost:5173

# OCR設定 (WSL+NVIDIA: gpu / Mac: cpu)
OCR_DEVICE=gpu
OCR_LANG=ch
